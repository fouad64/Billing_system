			</element>
			<element kind="textField" x="420" y="491" width="110" height="18" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" positionType="Float" blankWhenNull="true">
				<expression><![CDATA[$F{roaming_charge} + " EGP"]]></expression>
			</element>

			<!-- Promotional Savings -->
			<element kind="staticText" x="30" y="513" width="260" height="18" forecolor="#4CAF50" fontSize="10.0" bold="true" positionType="Float">
				<text><![CDATA[Promotional Savings]]></text>
			</element>
			<element kind="textField" x="420" y="513" width="110" height="18" forecolor="#4CAF50" fontSize="10.0" bold="true" hTextAlign="Right" positionType="Float" blankWhenNull="true">
				<expression><![CDATA["-" + $F{promotional_discount} + " EGP"]]></expression>
			</element>

			<!-- Taxes row -->
			<element kind="staticText" x="30" y="535" width="260" height="18" forecolor="#E0E0E0" fontSize="10.0" positionType="Float">
				<text><![CDATA[Government Tax (14%)]]></text>
			</element>
			<element kind="textField" x="420" y="535" width="110" height="18" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" positionType="Float" blankWhenNull="true">
				<expression><![CDATA[$F{taxes} + " EGP"]]></expression>
			</element>

			<!-- One-time row (Moved up after removing divider) -->
			<element kind="staticText" x="30" y="558" width="260" height="18" forecolor="#E0E0E0" fontSize="10.0" positionType="Float">
				<text><![CDATA[One-time Fees]]></text>
			</element>
			<element kind="textField" x="420" y="558" width="110" height="18" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" positionType="Float" blankWhenNull="true">
				<expression><![CDATA[$F{one_time_fees} + " EGP"]]></expression>
			</element>

			<!-- ===== TOTAL DUE BAR (Shifted up) ===== -->
			<element kind="rectangle" x="10" y="585" width="535" height="60" backcolor="#1A1A1A" radius="10" positionType="Float" mode="Opaque">
				<pen lineWidth="1.0" lineColor="#FF0000"/>
			</element>
			<!-- Red left accent stripe -->
			<element kind="rectangle" x="10" y="585" width="5" height="60" backcolor="#FF0000" positionType="Float" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<!-- Red circle with EGP symbol -->
			<element kind="ellipse" x="28" y="585" width="40" height="40" backcolor="#FF0000" positionType="Float" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="28" y="591" width="40" height="28" forecolor="#FFFFFF" fontSize="18.0" bold="true" hTextAlign="Center" vTextAlign="Middle" positionType="Float">
				<text><![CDATA[E£]]></text>
			</element>
			<!-- TOTAL DUE label -->
			<element kind="staticText" x="80" y="587" width="220" height="30" forecolor="#FF0000" fontSize="18.0" bold="true" vTextAlign="Middle" positionType="Float">
				<text><![CDATA[TOTAL DUE]]></text>
			</element>
			<!-- Total amount -->
			<element kind="textField" x="310" y="583" width="235" height="44" forecolor="#FF0000" fontSize="24.0" bold="true" hTextAlign="Right" vTextAlign="Middle" positionType="Float" blankWhenNull="true">
				<expression><![CDATA[$F{total_amount} + " EGP"]]></expression>
			</element>
		</band>
	</detail>

	<pageFooter height="40">
		<element kind="line" x="10" y="5" width="535" height="1" forecolor="#333333"/>
		<element kind="textField" x="10" y="18" width="170" height="20" forecolor="#808080" fontSize="9.0" blankWhenNull="true">
			<expression><![CDATA["Care: " + $P{COMPANY_CARE}]]></expression>
		</element>
		<element kind="textField" x="190" y="18" width="170" height="20" forecolor="#808080" fontSize="9.0" hTextAlign="Center" blankWhenNull="true">
			<expression><![CDATA[$P{COMPANY_WEB}]]></expression>
		</element>
		<element kind="textField" x="370" y="18" width="175" height="20" forecolor="#808080" fontSize="9.0" hTextAlign="Right" blankWhenNull="true">
			<expression><![CDATA[$P{COMPANY_EMAIL}]]></expression>
		</element>
	</pageFooter>
</jasperReport>
