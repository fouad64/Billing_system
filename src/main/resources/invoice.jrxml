<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="Invoice_FMRZ" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	
	<parameter name="BILL_ID" class="java.lang.Integer"/>
	<parameter name="LOGO_PATH" class="java.lang.Object"/>
	<parameter name="GROUP_NAME" class="java.lang.String"/>
	<parameter name="COMPANY_CARE" class="java.lang.String"/>
	<parameter name="COMPANY_WEB" class="java.lang.String"/>
	<parameter name="COMPANY_EMAIL" class="java.lang.String"/>
	<parameter name="VOICE_ICON" class="java.lang.Object"/>
	<parameter name="DATA_ICON" class="java.lang.Object"/>
	<parameter name="SMS_ICON" class="java.lang.Object"/>
	<parameter name="BILL_STATUS" class="java.lang.String"/>



	<query language="SQL"><![CDATA[
		SELECT 
			ua.name AS customer_name, ua.email AS customer_email,
			COALESCE(ua.address, 'N/A') AS customer_address, ua.id AS customer_id,
			b.billing_period_start, b.billing_period_end, b.billing_date,
			COALESCE(b.recurring_fees, 0) AS recurring_fees,
			COALESCE(b.one_time_fees, 0) AS one_time_fees,
			COALESCE(b.voice_usage, 0) AS voice_usage,
			COALESCE(b.data_usage, 0) AS data_usage,
			COALESCE(b.sms_usage, 0) AS sms_usage,
			COALESCE(b.overage_charge, 0) AS overage_charge,
			COALESCE(b.roaming_charge, 0) AS roaming_charge,
			COALESCE(b.promotional_discount, 0) AS promotional_discount,
			COALESCE(b.taxes, 0) AS taxes,
			COALESCE(b.total_amount, 0) AS total_amount,
			c.msisdn AS msisdn, rp.name AS rateplan_name
		FROM bill b
		JOIN contract c ON b.contract_id = c.id
		JOIN user_account ua ON c.user_account_id = ua.id
		JOIN rateplan rp ON c.rateplan_id = rp.id
		WHERE b.id = $P{BILL_ID}
	]]></query>

	<field name="customer_name" class="java.lang.String"/>
	<field name="customer_email" class="java.lang.String"/>
	<field name="customer_address" class="java.lang.String"/>
	<field name="customer_id" class="java.lang.Integer"/>
	<field name="billing_period_start" class="java.sql.Date"/>
	<field name="billing_period_end" class="java.sql.Date"/>
	<field name="billing_date" class="java.sql.Date"/>
	<field name="recurring_fees" class="java.math.BigDecimal"/>
	<field name="one_time_fees" class="java.math.BigDecimal"/>
	<field name="voice_usage" class="java.lang.Integer"/>
	<field name="data_usage" class="java.lang.Integer"/>
	<field name="sms_usage" class="java.lang.Integer"/>
	<field name="overage_charge" class="java.math.BigDecimal"/>
	<field name="roaming_charge" class="java.math.BigDecimal"/>
	<field name="promotional_discount" class="java.math.BigDecimal"/>
	<field name="taxes" class="java.math.BigDecimal"/>
	<field name="total_amount" class="java.math.BigDecimal"/>
	<field name="msisdn" class="java.lang.String"/>
	<field name="rateplan_name" class="java.lang.String"/>

	<background height="800">
		<element kind="rectangle" x="0" y="0" width="555" height="800" backcolor="#0A0A0A" mode="Opaque">
			<pen lineWidth="0.0"/>
		</element>
	</background>

	<title height="100">
		<!-- Top red accent bar -->
		<element kind="rectangle" x="10" y="0" width="535" height="3" backcolor="#FF0000" mode="Opaque">
			<pen lineWidth="0.0"/>
		</element>
		<!-- Logo -->
		<element kind="image" x="15" y="12" width="110" height="50" scaleImage="RetainShape" onErrorType="Blank">
			<expression><![CDATA[$P{LOGO_PATH}]]></expression>
		</element>
		<!-- Group name under logo -->
		<element kind="textField" x="15" y="65" width="220" height="14" forecolor="#808080" fontSize="9.0" blankWhenNull="true">
			<expression><![CDATA[$P{GROUP_NAME}]]></expression>
		</element>
		<!-- INVOICE large title -->
		<element kind="staticText" x="320" y="8" width="220" height="42" forecolor="#FF0000" fontSize="30.0" bold="true" hTextAlign="Right">
			<text><![CDATA[INVOICE]]></text>
		</element>
		<!-- Invoice number -->
		<element kind="textField" x="320" y="50" width="220" height="18" forecolor="#FFFFFF" fontSize="12.0" hTextAlign="Right" blankWhenNull="true">
			<expression><![CDATA["#INV-" + String.format("%04d", $P{BILL_ID})]]></expression>
		</element>
		<!-- Bill date -->
		<element kind="textField" x="320" y="68" width="220" height="14" forecolor="#808080" fontSize="9.0" hTextAlign="Right" blankWhenNull="true">
			<expression><![CDATA["Issued: " + new java.text.SimpleDateFormat("dd MMM yyyy").format($F{billing_date})]]></expression>
		</element>
		<!-- Separator line -->
		<element kind="line" x="10" y="92" width="535" height="1" forecolor="#FF0000">
			<pen lineWidth="1.0"/>
		</element>
	</title>

	<detail>
		<!-- BAND 1: CUSTOMER & PROFILE -->
		<band height="145">
			<element kind="rectangle" x="10" y="8" width="258" height="130" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#2A2A2A"/>
			</element>
			<element kind="staticText" x="25" y="18" width="228" height="18" forecolor="#FF0000" fontSize="11.0" bold="true">
				<text><![CDATA[CUSTOMER DATA]]></text>
			</element>
			<element kind="line" x="25" y="38" width="40" height="1" forecolor="#FF0000">
				<pen lineWidth="2.0"/>
			</element>
			<element kind="textField" x="25" y="46" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Name: " + $F{customer_name}]]></expression>
			</element>
			<element kind="textField" x="25" y="64" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["MSISDN: " + $F{msisdn}]]></expression>
			</element>
			<element kind="textField" x="25" y="82" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Email: " + $F{customer_email}]]></expression>
			</element>
			<element kind="textField" x="25" y="100" width="228" height="30" forecolor="#808080" fontSize="9.0" blankWhenNull="true">
				<expression><![CDATA[$F{customer_address}]]></expression>
			</element>

			<element kind="rectangle" x="287" y="8" width="258" height="130" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#2A2A2A"/>
			</element>
			<element kind="staticText" x="302" y="18" width="228" height="18" forecolor="#FF0000" fontSize="11.0" bold="true">
				<text><![CDATA[PROFILE]]></text>
			</element>
			<element kind="line" x="302" y="38" width="40" height="1" forecolor="#FF0000">
				<pen lineWidth="2.0"/>
			</element>
			<element kind="textField" x="302" y="46" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Plan: " + $F{rateplan_name}]]></expression>
			</element>
			<element kind="textField" x="302" y="64" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Period: " + new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{billing_period_start})]]></expression>
			</element>
			<element kind="textField" x="302" y="82" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Billed: " + new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{billing_date})]]></expression>
			</element>
			<element kind="rectangle" x="350" y="104" width="140" height="26" backcolor="#FF0000" radius="4" mode="Opaque">
				<pen lineWidth="1.5" lineColor="#FF0000"/>
			</element>
			<element kind="textField" x="350" y="106" width="140" height="22" forecolor="#FFFFFF" fontSize="13.0" bold="true" hTextAlign="Center" blankWhenNull="true">
				<expression><![CDATA[$P{BILL_STATUS}.toUpperCase()]]></expression>
			</element>
		</band>

		<!-- BAND 2: SERVICE USAGE SUMMARY -->
		<band height="75" splitType="Stretch">
			<element kind="ellipse" x="10" y="8" width="8" height="8" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="24" y="6" width="220" height="18" forecolor="#FF0000" fontSize="12.0" bold="true">
				<text><![CDATA[SERVICE USAGE]]></text>
			</element>
			<element kind="rectangle" x="10" y="28" width="535" height="42" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#2A2A2A"/>
			</element>
			<!-- Voice column -->
			<element kind="staticText" x="47" y="34" width="70" height="10" forecolor="#808080" fontSize="7.0" hTextAlign="Center">
				<text><![CDATA[VOICE MINS]]></text>
			</element>
			<element kind="textField" x="47" y="44" width="70" height="20" forecolor="#FFFFFF" fontSize="14.0" bold="true" hTextAlign="Center" vTextAlign="Middle" blankWhenNull="true">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{voice_usage} / 60.0)]]></expression>
			</element>
			<element kind="line" x="188" y="34" width="1" height="30" forecolor="#2A2A2A"/>
			<!-- Data column -->
			<element kind="staticText" x="242" y="34" width="70" height="10" forecolor="#808080" fontSize="7.0" hTextAlign="Center">
				<text><![CDATA[DATA GB]]></text>
			</element>
			<element kind="textField" x="242" y="44" width="70" height="20" forecolor="#FFFFFF" fontSize="14.0" bold="true" hTextAlign="Center" vTextAlign="Middle" blankWhenNull="true">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{data_usage} / 1073741824.0)]]></expression>
			</element>
			<element kind="line" x="377" y="34" width="1" height="30" forecolor="#2A2A2A"/>
			<!-- SMS column -->
			<element kind="staticText" x="442" y="34" width="70" height="10" forecolor="#808080" fontSize="7.0" hTextAlign="Center">
				<text><![CDATA[SMS]]></text>
			</element>
			<element kind="textField" x="442" y="44" width="70" height="20" forecolor="#FFFFFF" fontSize="14.0" bold="true" hTextAlign="Center" vTextAlign="Middle" blankWhenNull="true">
				<expression><![CDATA[$F{sms_usage}]]></expression>
			</element>
		</band>

		<!-- BAND 3: DETAILED USAGE TABLE -->
		<band height="130" splitType="Stretch">
			<element kind="ellipse" x="10" y="10" width="8" height="8" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="24" y="8" width="260" height="18" forecolor="#FF0000" fontSize="12.0" bold="true">
				<text><![CDATA[DETAILED USAGE BREAKDOWN]]></text>
			</element>
			
			<element kind="rectangle" x="10" y="32" width="535" height="88" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#333333"/>
			</element>
			
			<element kind="rectangle" x="10" y="32" width="535" height="20" backcolor="#1A1A1A" radius="10">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="20" y="35" width="80" height="14" forecolor="#AAAAAA" fontSize="8.0" bold="true">
				<text><![CDATA[SERVICE]]></text>
			</element>
			<element kind="staticText" x="110" y="35" width="70" height="14" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Center">
				<text><![CDATA[QUOTA]]></text>
			</element>
			<element kind="staticText" x="190" y="35" width="70" height="14" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Center">
				<text><![CDATA[USED]]></text>
			</element>
			<element kind="staticText" x="270" y="35" width="60" height="14" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Center">
				<text><![CDATA[RATE]]></text>
			</element>
			<element kind="staticText" x="340" y="35" width="80" height="14" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Right">
				<text><![CDATA[AMOUNT]]></text>
			</element>
			<element kind="staticText" x="430" y="35" width="100" height="14" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Center">
				<text><![CDATA[NOTE]]></text>
			</element>
			
			<element kind="staticText" x="20" y="60" width="80" height="16" forecolor="#FFFFFF" fontSize="10.0">
				<text><![CDATA[📱 Voice]]></text>
			</element>
			<element kind="staticText" x="110" y="60" width="70" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Center">
				<text><![CDATA[Unlimited]]></text>
			</element>
			<element kind="textField" x="190" y="60" width="70" height="16" forecolor="#00FF00" fontSize="9.0" hTextAlign="Center">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0").format($F{voice_usage} / 60.0) + " min"]]></expression>
			</element>
			<element kind="staticText" x="270" y="60" width="60" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Center">
				<text><![CDATA[—]]></text>
			</element>
			<element kind="staticText" x="340" y="60" width="80" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Right">
				<text><![CDATA[Included]]></text>
			</element>
			<element kind="staticText" x="430" y="60" width="100" height="16" forecolor="#00FF00" fontSize="8.0" hTextAlign="Center">
				<text><![CDATA[No Charge]]></text>
			</element>
			
			<element kind="staticText" x="20" y="80" width="80" height="16" forecolor="#FFFFFF" fontSize="10.0">
				<text><![CDATA[📊 Data]]></text>
			</element>
			<element kind="staticText" x="110" y="80" width="70" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Center">
				<text><![CDATA[10 GB]]></text>
			</element>
			<element kind="textField" x="190" y="80" width="70" height="16" forecolor="#00FF00" fontSize="9.0" hTextAlign="Center">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{data_usage} / 1024.0) + " GB"]]></expression>
			</element>
			<element kind="staticText" x="270" y="80" width="60" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Center">
				<text><![CDATA[0.50]]></text>
			</element>
			<element kind="textField" x="340" y="80" width="80" height="16" forecolor="#FFFFFF" fontSize="9.0" hTextAlign="Right">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format(Math.max(0, ($F{data_usage} / 1024.0 - 10) * 0.50)) + " EGP"]]></expression>
			</element>
			<element kind="staticText" x="430" y="80" width="100" height="16" forecolor="#888888" fontSize="8.0" hTextAlign="Center">
				<text><![CDATA[Overage]]></text>
			</element>
			
			<element kind="staticText" x="20" y="100" width="80" height="16" forecolor="#FFFFFF" fontSize="10.0">
				<text><![CDATA[💬 SMS]]></text>
			</element>
			<element kind="staticText" x="110" y="100" width="70" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Center">
				<text><![CDATA[Unlimited]]></text>
			</element>
			<element kind="textField" x="190" y="100" width="70" height="16" forecolor="#00FF00" fontSize="9.0" hTextAlign="Center">
				<expression><![CDATA[$F{sms_usage} + " msgs"]]></expression>
			</element>
			<element kind="staticText" x="270" y="100" width="60" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Center">
				<text><![CDATA[—]]></text>
			</element>
			<element kind="staticText" x="340" y="100" width="80" height="16" forecolor="#AAAAAA" fontSize="9.0" hTextAlign="Right">
				<text><![CDATA[Included]]></text>
			</element>
			<element kind="staticText" x="430" y="100" width="100" height="16" forecolor="#00FF00" fontSize="8.0" hTextAlign="Center">
				<text><![CDATA[No Charge]]></text>
			</element>
</band>
		<!-- BAND 4: FINANCIAL SUMMARY -->
		<band height="235">
			<element kind="ellipse" x="10" y="10" width="8" height="8" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="24" y="8" width="260" height="18" forecolor="#FF0000" fontSize="12.0" bold="true">
				<text><![CDATA[FINANCIAL SUMMARY (INC. TAXES)]]></text>
			</element>
			<element kind="rectangle" x="10" y="32" width="535" height="135" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#333333"/>
			</element>
			<element kind="staticText" x="30" y="40" width="260" height="16" forecolor="#E0E0E0" fontSize="10.0">
				<text><![CDATA[Monthly Subscription]]></text>
			</element>
			<element kind="textField" x="420" y="40" width="110" height="16" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" blankWhenNull="true">
				<expression><![CDATA[$F{recurring_fees} + " EGP"]]></expression>
			</element>
			
			<element kind="staticText" x="30" y="120" width="260" height="16" forecolor="#E0E0E0" fontSize="10.0">
				<text><![CDATA[Government Tax (14%)]]></text>
			</element>
			<element kind="textField" x="420" y="120" width="110" height="16" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" blankWhenNull="true">
				<expression><![CDATA[$F{taxes} + " EGP"]]></expression>
			</element>
			<element kind="staticText" x="30" y="140" width="260" height="16" forecolor="#E0E0E0" fontSize="10.0" vTextAlign="Middle">
				<text><![CDATA[One-time Fees]]></text>
			</element>
			<element kind="textField" x="420" y="140" width="110" height="16" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true">
				<expression><![CDATA[$F{one_time_fees} + " EGP"]]></expression>
			</element>
			
			<element kind="staticText" x="30" y="60" width="260" height="16" forecolor="#E0E0E0" fontSize="10.0">
				<text><![CDATA[Overage Charges]]></text>
			</element>
			<element kind="textField" x="420" y="60" width="110" height="16" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" blankWhenNull="true">
				<expression><![CDATA[$F{overage_charge} + " EGP"]]></expression>
			</element>
			
			<element kind="staticText" x="30" y="80" width="260" height="16" forecolor="#E0E0E0" fontSize="10.0">
				<text><![CDATA[Roaming Charges]]></text>
			</element>
			<element kind="textField" x="420" y="80" width="110" height="16" forecolor="#FFFFFF" fontSize="10.0" hTextAlign="Right" blankWhenNull="true">
				<expression><![CDATA[$F{roaming_charge} + " EGP"]]></expression>
			</element>
			
			<element kind="staticText" x="30" y="100" width="260" height="16" forecolor="#00FF00" fontSize="10.0">
				<text><![CDATA[Promotional Discount]]></text>
			</element>
			<element kind="textField" x="420" y="100" width="110" height="16" forecolor="#00FF00" fontSize="10.0" hTextAlign="Right" blankWhenNull="true">
				<expression><![CDATA["-" + $F{promotional_discount} + " EGP"]]></expression>
			</element>
 
			<element kind="rectangle" x="10" y="175" width="535" height="55" backcolor="#1A1A1A" radius="10" mode="Opaque">
				<pen lineWidth="1.0" lineColor="#FF0000"/>
			</element>
			<element kind="rectangle" x="10" y="175" width="5" height="55" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="ellipse" x="28" y="182" width="40" height="40" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="28" y="188" width="40" height="28" forecolor="#FFFFFF" fontSize="18.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
				<text><![CDATA[E£]]></text>
			</element>
			<element kind="staticText" x="80" y="187" width="220" height="30" forecolor="#FF0000" fontSize="18.0" bold="true" vTextAlign="Middle">
				<text><![CDATA[TOTAL DUE]]></text>
			</element>
			<element kind="textField" x="310" y="180" width="235" height="44" forecolor="#FF0000" fontSize="24.0" bold="true" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true">
				<expression><![CDATA[$F{total_amount} + " EGP"]]></expression>
			</element>
		</band>
	</detail>

	<pageFooter height="40">
		<element kind="line" x="10" y="5" width="535" height="1" forecolor="#333333"/>
		<element kind="textField" x="10" y="18" width="170" height="20" forecolor="#808080" fontSize="9.0" blankWhenNull="true">
			<expression><![CDATA["Care: " + $P{COMPANY_CARE}]]></expression>
		</element>
		<element kind="textField" x="190" y="18" width="170" height="20" forecolor="#808080" fontSize="9.0" hTextAlign="Center" blankWhenNull="true">
			<expression><![CDATA[$P{COMPANY_WEB}]]></expression>
		</element>
		<element kind="textField" x="370" y="18" width="175" height="20" forecolor="#808080" fontSize="9.0" hTextAlign="Right" blankWhenNull="true">
			<expression><![CDATA[$P{COMPANY_EMAIL}]]></expression>
		</element>
	</pageFooter>
</jasperReport>
