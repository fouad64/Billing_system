			</element>
			<element kind="textField" x="442" y="248" width="70" height="24" forecolor="#FFFFFF" fontSize="16.0" bold="true" hTextAlign="Center" blankWhenNull="true">
				<expression><![CDATA[$F{sms_usage}]]></expression>
			</element>


			<!-- ===== DETAILED USAGE BREAKDOWN SECTION ===== -->
			<element kind="ellipse" x="10" y="308" width="8" height="8" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="24" y="306" width="260" height="18" forecolor="#FF0000" fontSize="12.0" bold="true">
				<text><![CDATA[DETAILED USAGE BREAKDOWN]]></text>
			</element>
			
			<element kind="component" x="10" y="330" width="535" height="80">
				<component kind="table" xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" >
					<datasetRun uuid="c3d4e5f6-a7b8-9012-abcd-ef3456789012" subDataset="usageBreakdown">
						<parameter name="BILL_ID">
							<expression><![CDATA[$P{BILL_ID}]]></expression>
						</parameter>
					</datasetRun>
					<column kind="single" width="110" uuid="d4e5f6a7-b8c9-0123-abcd-ef4567890123">
						<columnHeader style="Table_Header" height="22">
							<element kind="staticText" x="5" y="0" width="100" height="22" forecolor="#AAAAAA" fontSize="8.0" bold="true" vTextAlign="Middle">
								<text><![CDATA[Service]]></text>
							</element>
						</columnHeader>
						<detailCell style="Table_Cell" height="15">
							<element kind="textField" x="5" y="0" width="100" height="15" forecolor="#FFFFFF" fontSize="8.0" vTextAlign="Middle">
