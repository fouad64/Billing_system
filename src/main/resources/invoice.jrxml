			</element>

			<!-- ===== SERVICE USAGE SECTION ===== -->
			<element kind="ellipse" x="10" y="166" width="8" height="8" backcolor="#FF0000" mode="Opaque">
				<pen lineWidth="0.0"/>
			</element>
			<element kind="staticText" x="24" y="164" width="220" height="18" forecolor="#FF0000" fontSize="12.0" bold="true">
				<text><![CDATA[SERVICE USAGE]]></text>
			</element>
			<!-- Usage card -->
			<element kind="rectangle" x="10" y="188" width="535" height="100" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#2A2A2A"/>
			</element>
			<!-- Voice column -->
			<element kind="image" x="67" y="198" width="30" height="30" scaleImage="RetainShape" onErrorType="Blank">
				<expression><![CDATA["/Pictures/voice.svg"]]></expression>
			</element>
			<element kind="staticText" x="47" y="232" width="70" height="14" forecolor="#808080" fontSize="8.0" hTextAlign="Center">
				<text><![CDATA[VOICE MINS]]></text>
			</element>
			<element kind="textField" x="47" y="248" width="70" height="24" forecolor="#FFFFFF" fontSize="16.0" bold="true" hTextAlign="Center" blankWhenNull="true">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{voice_usage} / 60.0)]]></expression>
			</element>
			<!-- Vertical divider 1 -->
			<element kind="line" x="188" y="200" width="1" height="70" forecolor="#2A2A2A"/>
			<!-- Data column -->
			<element kind="image" x="262" y="198" width="30" height="30" scaleImage="RetainShape" onErrorType="Blank">
				<expression><![CDATA["/Pictures/data.svg"]]></expression>
			</element>
			<element kind="staticText" x="242" y="232" width="70" height="14" forecolor="#808080" fontSize="8.0" hTextAlign="Center">
				<text><![CDATA[DATA GB]]></text>
			</element>
			<element kind="textField" x="242" y="248" width="70" height="24" forecolor="#FFFFFF" fontSize="16.0" bold="true" hTextAlign="Center" blankWhenNull="true">
				<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{data_usage} / 1024.0)]]></expression>
			</element>
			<!-- Vertical divider 2 -->
			<element kind="line" x="377" y="200" width="1" height="70" forecolor="#2A2A2A"/>
			<!-- SMS column -->
			<element kind="image" x="462" y="198" width="30" height="30" scaleImage="RetainShape" onErrorType="Blank">
