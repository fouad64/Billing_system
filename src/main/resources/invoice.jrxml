			</element>
			<element kind="staticText" x="25" y="20" width="228" height="18" forecolor="#FF0000" fontSize="11.0" bold="true">
				<text><![CDATA[CUSTOMER DATA]]></text>
			</element>
			<element kind="line" x="25" y="40" width="40" height="1" forecolor="#FF0000">
				<pen lineWidth="2.0"/>
			</element>
			<element kind="textField" x="25" y="50" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Name: " + $F{customer_name}]]></expression>
			</element>
			<element kind="textField" x="25" y="68" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["MSISDN: " + $F{msisdn}]]></expression>
			</element>
			<element kind="textField" x="25" y="86" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Email: " + $F{customer_email}]]></expression>
			</element>
			<element kind="textField" x="25" y="106" width="228" height="30" forecolor="#808080" fontSize="9.0" blankWhenNull="true">
				<expression><![CDATA[$F{customer_address}]]></expression>
			</element>

			<!-- ===== PROFILE CARD ===== -->
			<element kind="rectangle" x="287" y="8" width="258" height="138" backcolor="#121212" radius="10" mode="Opaque">
				<pen lineWidth="0.5" lineColor="#2A2A2A"/>
			</element>
			<element kind="staticText" x="302" y="20" width="228" height="18" forecolor="#FF0000" fontSize="11.0" bold="true">
				<text><![CDATA[PROFILE]]></text>
			</element>
			<element kind="line" x="302" y="40" width="40" height="1" forecolor="#FF0000">
				<pen lineWidth="2.0"/>
			</element>
			<element kind="textField" x="302" y="50" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Plan: " + $F{rateplan_name}]]></expression>
			</element>
			<element kind="textField" x="302" y="68" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
