							</element>
						</detailCell>
					</column>
					<column kind="single" width="80" uuid="e5f6a7b8-c9d0-1234-abcd-ef5678901234">
						<columnHeader style="Table_Header" height="22">
							<element kind="staticText" x="0" y="0" width="75" height="22" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Right" vTextAlign="Middle">
								<text><![CDATA[Quota]]></text>
							</element>
						</columnHeader>
						<detailCell style="Table_Cell" height="15">
							<element kind="textField" x="0" y="0" width="75" height="15" forecolor="#E0E0E0" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true">
								<expression><![CDATA[$F{quota} == null ? "—" : $F{quota} + " units"]]></expression>
							</element>
						</detailCell>
					</column>
					<column kind="single" width="85" uuid="f6a7b8c9-d0e1-2345-abcd-ef6789012345">
						<columnHeader style="Table_Header" height="22">
							<element kind="staticText" x="0" y="0" width="80" height="22" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Right" vTextAlign="Middle">
								<text><![CDATA[Used]]></text>
							</element>
						</columnHeader>
						<detailCell style="Table_Cell" height="15">
							<element kind="textField" x="0" y="0" width="80" height="15" forecolor="#E0E0E0" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true">
								<expression><![CDATA[$F{consumed} == null ? "0" : $F{service_type}.matches(".*data.*") ? new java.text.DecimalFormat("#,##0.00").format($F{consumed} / 1024.0) + " GB" : ($F{service_type}.matches(".*voice.*") ? new java.text.DecimalFormat("#,##0.00").format($F{consumed} / 60.0) + " min" : $F{consumed} + " msgs") ]]></expression>
							</element>
						</detailCell>
					</column>
					<column kind="single" width="80" uuid="01234567-89ab-cdef-0123-456789abcdef">
						<columnHeader style="Table_Header" height="22">
							<element kind="staticText" x="0" y="0" width="75" height="22" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Right" vTextAlign="Middle">
								<text><![CDATA[Rate]]></text>
							</element>
						</columnHeader>
						<detailCell style="Table_Cell" height="15">
							<element kind="textField" x="0" y="0" width="75" height="15" forecolor="#E0E0E0" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true">
								<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{unit_rate})]]></expression>
							</element>
						</detailCell>
					</column>
					<column kind="single" width="100" uuid="12345678-9abc-def0-1234-567890abcdef">
						<columnHeader style="Table_Header" height="22">
							<element kind="staticText" x="0" y="0" width="95" height="22" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Right" vTextAlign="Middle">
								<text><![CDATA[Amount]]></text>
							</element>
						</columnHeader>
						<detailCell style="Table_Cell" height="15">
							<element kind="textField" x="0" y="0" width="95" height="15" forecolor="#FFFFFF" fontSize="8.0" bold="true" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true">
								<expression><![CDATA[new java.text.DecimalFormat("#,##0.00").format($F{line_total}) + " EGP"]]></expression>
							</element>
						</detailCell>
					</column>
					<column kind="single" width="80" uuid="23456789-abcd-ef01-2345-678901abcdef">
						<columnHeader style="Table_Header" height="22">
							<element kind="staticText" x="0" y="0" width="75" height="22" forecolor="#AAAAAA" fontSize="8.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
								<text><![CDATA[Note]]></text>
							</element>
						</columnHeader>
						<detailCell style="Table_Cell" height="15">
							<element kind="textField" x="0" y="0" width="75" height="15" forecolor="#888888" fontSize="7.0" hTextAlign="Center" vTextAlign="Middle" blankWhenNull="true">
								<expression><![CDATA[$F{is_promotional} ? "PROMO ★" : ($F{is_roaming} ? "ROAMING" : "")]]></expression>
							</element>
						</detailCell>
					</column>
				</component>
			</element>

			<!-- ===== FINANCIAL SUMMARY SECTION ===== -->
