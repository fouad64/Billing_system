			</element>
			<element kind="textField" x="302" y="86" width="228" height="16" forecolor="#FFFFFF" fontSize="10.0" blankWhenNull="true">
				<expression><![CDATA["Billed: " + new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{billing_date})]]></expression>
			</element>
			<!-- Status badge -->
			<element kind="rectangle" x="350" y="112" width="140" height="26" backcolor="#FF0000" radius="4" mode="Opaque">
				<pen lineWidth="1.5" lineColor="#FF0000"/>
			</element>
			<element kind="textField" x="350" y="114" width="140" height="22" forecolor="#FFFFFF" fontSize="13.0" bold="true" hTextAlign="Center" blankWhenNull="true">
